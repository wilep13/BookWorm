<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.BookWorm" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/color_primary_1</item>
        <item name="colorPrimaryVariant">@color/color_primary_2</item>
        <item name="colorSecondary">@color/color_primary_2</item>
        <item name="android:colorBackground">@color/color_secondary_1</item>
        <item name="android:windowBackground">@color/color_secondary_1</item>
        <!-- NB: jangan set android:fontFamily di level tema — pada Material3 itu menimpa
             android:fontFamily inline pada TextView (mis. heading Playfair jadi ikut Montserrat).
             Setiap TextView di app sudah menetapkan fontFamily-nya sendiri secara eksplisit. -->
    </style>

    <style name="Theme.BookWorm" parent="Base.Theme.BookWorm" />

    <!-- Theme khusus SplashActivity: system splash screen tidak terlihat -->
    <style name="Theme.BookWorm.Splash" parent="Theme.SplashScreen">
        <item name="android:windowBackground">@color/color_secondary_2</item>
        <item name="android:windowSplashScreenBackground">@color/color_secondary_2</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_splash_transparent</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@color/color_secondary_2</item>
        <item name="windowSplashScreenBackground">@color/color_secondary_2</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_transparent</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/color_secondary_2</item>
        <item name="postSplashScreenTheme">@style/Theme.BookWorm</item>
    </style>

    <style name="TextAppearance.BookWorm.H1" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">@font/montserrat</item>
        <item name="fontFamily">@font/montserrat</item>
        <item name="android:textSize">45sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/color_primary_3</item>
    </style>

    <style name="TextAppearance.BookWorm.H2" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">@font/montserrat</item>
        <item name="fontFamily">@font/montserrat</item>
        <item name="android:textSize">27sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/color_primary_3</item>
    </style>

    <style name="TextAppearance.BookWorm.Subtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/montserrat</item>
        <item name="fontFamily">@font/montserrat</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/color_primary_3</item>
    </style>

    <style name="TextAppearance.BookWorm.Label" parent="TextAppearance.Material3.BodySmall">
        <item name="android:fontFamily">@font/montserrat</item>
        <item name="fontFamily">@font/montserrat</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/color_primary_2</item>
    </style>

    <style name="TextAppearance.BookWorm.Button" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">@font/montserrat</item>
        <item name="fontFamily">@font/montserrat</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextAppearance.BookWorm.Caption" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/montserrat</item>
        <item name="fontFamily">@font/montserrat</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/color_primary_1</item>
    </style>

    <style name="TextAppearance.BookWorm.CardTitle" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/montserrat</item>
        <item name="fontFamily">@font/montserrat</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/color_primary_3</item>
    </style>

    <style name="TextAppearance.BookWorm.CardAuthor" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/playfair_display</item>
        <item name="fontFamily">@font/playfair_display</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/color_primary_1</item>
    </style>

    <style name="TextAppearance.BookWorm.Tagline" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/playfair_display</item>
        <item name="fontFamily">@font/playfair_display</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/color_primary_3</item>
    </style>

    <!-- ── TextInputLayout component ── -->
    <style name="Widget.BookWorm.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/input_corner_radius</item>
        <item name="boxBackgroundColor">@color/white</item>
        <item name="hintEnabled">false</item>
        <item name="errorEnabled">true</item>
        <item name="errorIconDrawable">@null</item>
        <item name="errorTextColor">@color/color_error</item>
        <item name="errorTextAppearance">@style/TextAppearance.BookWorm.InputError</item>
    </style>

    <style name="TextAppearance.BookWorm.InputError" parent="TextAppearance.Material3.BodySmall">
        <item name="android:fontFamily">@font/montserrat</item>
        <item name="android:textColor">@color/color_error</item>
        <item name="android:textSize">11sp</item>
    </style>

    <!-- ── Button components ── -->
    <style name="Widget.BookWorm.Button" parent="Widget.Material3.Button">
        <item name="android:fontFamily">@font/montserrat</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="backgroundTint">@null</item>
    </style>

    <style name="Widget.BookWorm.Button.Primary">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/button_primary_height</item>
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textSize">16sp</item>   <!-- Figma: Button Montserrat Bold 16sp -->
        <item name="android:textStyle">bold</item>
        <item name="android:elevation">4dp</item>
    </style>

    <!-- Landing "GET STARTED" — Figma: Montserrat Bold 12sp, radius 10, padding 12×5, wrap content -->
    <style name="Widget.BookWorm.Button.Splash">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_button_splash</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">5dp</item>
        <item name="android:paddingBottom">5dp</item>
    </style>
</resources>
