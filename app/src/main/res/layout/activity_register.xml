<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_secondary_1"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Hero block (peach background) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/color_secondary_1"
            android:paddingStart="33dp"
            android:paddingEnd="33dp"
            android:paddingTop="56dp"
            android:paddingBottom="10dp">

            <!-- Book decorations (absolute via FrameLayout overlay) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/logo_height"
                android:clipChildren="false">

                <!-- Logo -->
                <ImageView
                    android:layout_width="@dimen/logo_width"
                    android:layout_height="@dimen/logo_height"
                    android:src="@drawable/ic_bookworm_logo_app"
                    android:scaleType="fitXY"
                    android:contentDescription="@string/app_name" />

                <!-- Book decorations top-right -->
                <ImageView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_gravity="end"
                    android:layout_marginTop="0dp"
                    android:layout_marginEnd="4dp"
                    android:alpha="0.50"
                    android:rotation="-12"
                    android:scaleType="fitXY"
                    android:src="@drawable/img_book_decoration"
                    android:contentDescription="@null" />
                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="end"
                    android:layout_marginTop="38dp"
                    android:layout_marginEnd="48dp"
                    android:alpha="0.40"
                    android:rotation="14"
                    android:scaleType="fitXY"
                    android:src="@drawable/img_book_decoration"
                    android:contentDescription="@null" />
                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="end"
                    android:layout_marginTop="80dp"
                    android:layout_marginEnd="0dp"
                    android:alpha="0.45"
                    android:rotation="-6"
                    android:scaleType="fitXY"
                    android:src="@drawable/img_book_decoration"
                    android:contentDescription="@null" />
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end"
                    android:layout_marginTop="56dp"
                    android:layout_marginEnd="80dp"
                    android:alpha="0.32"
                    android:rotation="20"
                    android:scaleType="fitXY"
                    android:src="@drawable/img_book_decoration"
                    android:contentDescription="@null" />
            </FrameLayout>

            <!-- "Hello !" heading (Figma: Playfair Display Bold 40sp) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/playfair_display"
                android:text="@string/label_hello"
                android:textColor="@color/color_primary_3"
                android:textSize="40sp"
                android:textStyle="bold" />

            <!-- Subtitle (Figma: Montserrat Bold 14sp) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:text="@string/subtitle_join_library"
                android:textColor="@color/color_primary_3"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ── Folder tab row (peach background) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/color_secondary_1">

            <!-- LOGIN tab — INACTIVE -->
            <TextView
                android:id="@+id/tab_login"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="20dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/tab_login"
                android:textColor="@color/color_primary_2"
                android:textSize="14sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <!-- REGISTER tab — ACTIVE -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_tab_folder">

                <!-- Underline at top -->
                <View
                    android:layout_width="17dp"
                    android:layout_height="2dp"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="8dp"
                    android:background="@color/color_primary_2" />

                <TextView
                    android:id="@+id/tab_register"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingTop="12dp"
                    android:paddingBottom="20dp"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/tab_register"
                    android:textColor="@color/color_primary_2"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </FrameLayout>
        </LinearLayout>

        <!-- ── Form area (peach background) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/color_secondary_2"
            android:paddingStart="33dp"
            android:paddingEnd="33dp"
            android:paddingTop="26dp"
            android:paddingBottom="60dp">

            <!-- Username label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:text="@string/label_username"
                android:textColor="@color/color_primary_2"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_username"
                style="@style/Widget.BookWorm.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_username"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:hint="@string/hint_username"
                    android:imeOptions="actionNext"
                    android:inputType="textPersonName"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="13dp"
                    android:paddingBottom="13dp"
                    android:textColor="@color/color_primary_2"
                    android:textColorHint="@color/color_hint"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Email label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/label_email"
                android:textColor="@color/color_primary_2"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_email"
                style="@style/Widget.BookWorm.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:hint="@string/hint_email"
                    android:imeOptions="actionNext"
                    android:inputType="textEmailAddress"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="13dp"
                    android:paddingBottom="13dp"
                    android:textColor="@color/color_primary_2"
                    android:textColorHint="@color/color_hint"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/label_password"
                android:textColor="@color/color_primary_2"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_password"
                style="@style/Widget.BookWorm.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:hint="@string/hint_password"
                    android:imeOptions="actionNext"
                    android:inputType="textPassword"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="13dp"
                    android:paddingBottom="13dp"
                    android:textColor="@color/color_primary_2"
                    android:textColorHint="@color/color_hint"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Confirm password label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/label_confirm_password"
                android:textColor="@color/color_primary_2"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_confirm_password"
                style="@style/Widget.BookWorm.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_confirm_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:hint="@string/hint_confirm_password"
                    android:imeOptions="actionDone"
                    android:inputType="textPassword"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="13dp"
                    android:paddingBottom="13dp"
                    android:textColor="@color/color_primary_2"
                    android:textColorHint="@color/color_hint"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- REGISTER button -->
            <Button
                android:id="@+id/btn_register"
                style="@style/Widget.BookWorm.Button.Primary"
                android:layout_marginTop="8dp"
                android:text="@string/btn_create_account" />

            <!-- Footer hint -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:fontFamily="@font/montserrat"
                android:gravity="center"
                android:text="@string/footer_tap_register"
                android:textColor="@color/color_grey"
                android:textSize="11sp"
                android:fontWeight="500" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
