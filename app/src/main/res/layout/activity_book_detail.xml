<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_secondary_1"
    tools:context=".ui.home.BookDetailActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="40dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="64dp">

            <!-- ── Top meta strip: Published | Pages | Genre (caramel background, chip overlays) ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@color/color_primary_1"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:orientation="horizontal">

                <!-- Published chip -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="5dp"
                    android:layout_marginEnd="4dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_chip">

                    <TextView
                        android:id="@+id/tv_year"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/playfair_display"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="1925" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/label_published"
                        android:textColor="@color/color_secondary_2"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />
                </LinearLayout>

                <!-- Pages chip -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="5dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_chip">

                    <TextView
                        android:id="@+id/tv_pages"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/playfair_display"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="218" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/label_pages"
                        android:textColor="@color/color_secondary_2"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />
                </LinearLayout>

                <!-- Genre chip -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="5dp"
                    android:layout_marginStart="4dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_chip">

                    <TextView
                        android:id="@+id/tv_genre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/playfair_display"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="Fiction" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/label_genre"
                        android:textColor="@color/color_secondary_2"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── Top bar: back button + title ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="16dp"
                android:paddingBottom="4dp">

                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_back"
                    android:tint="@color/color_primary_3"
                    android:background="@drawable/bg_back_btn"
                    android:scaleType="center"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/content_description_back" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/label_book_detail"
                    android:textColor="@color/color_primary_3"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ── Hero cover (flat cover art, centered) ── -->
            <ImageView
                android:id="@+id/book_cover"
                android:layout_width="@dimen/cover_detail_width"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:elevation="8dp"
                android:contentDescription="@null"
                tools:src="@drawable/cover_art_gatsby" />

            <!-- ── Title block ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="24dp"
                android:gravity="center">

                <!-- Tag badge -->
                <TextView
                    android:id="@+id/tv_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tag_badge"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:fontFamily="@font/montserrat"
                    android:textColor="@color/color_primary_2"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    tools:text="FICTION" />

                <!-- Book title -->
                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/montserrat"
                    android:textColor="@color/color_primary_2"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.1"
                    tools:text="The Great Gatsby" />

                <!-- Author -->
                <TextView
                    android:id="@+id/tv_author"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/playfair_display"
                    android:textColor="@color/color_primary_2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="F. Scott Fitzgerald" />
            </LinearLayout>

            <!-- ── Caramel lower section: ABOUT + blurb + order card ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:background="@color/color_primary_1"
                android:paddingBottom="32dp">

            <!-- "ABOUT THIS BOOK" header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/color_primary_1"
                android:fontFamily="@font/montserrat"
                android:text="@string/label_about_book"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:gravity="center"
                android:paddingTop="16dp"
                android:paddingBottom="10dp" />

            <!-- Divider line below "ABOUT THIS BOOK" (matches Figma vector separator) -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/white"
                android:alpha="0.35" />

            <!-- ── Blurb with drop cap: FrameLayout overlay + LeadingMarginSpan2 in Java ── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="14dp"
                android:paddingBottom="4dp"
                android:clipToPadding="false">

                <!-- Full-width blurb; first 2 lines indented via LeadingMarginSpan2 at runtime -->
                <TextView
                    android:id="@+id/tv_blurb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:fontFamily="@font/montserrat"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.5"
                    android:gravity="start"
                    tools:text="n my younger and more vulnerable years my father gave me some advice that I have been turning over in my mind ever since." />

                <!-- Drop cap: negative marginTop compensates for Playfair Display's large ascender
                     space above the cap letter (~6sp) vs Montserrat's smaller top padding -->
                <TextView
                    android:id="@+id/tv_blurb_dropcap"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_marginTop="-10dp"
                    android:fontFamily="@font/playfair_display"
                    android:textColor="@color/white"
                    android:textSize="52sp"
                    android:textStyle="bold"
                    android:includeFontPadding="false"
                    tools:text="I" />
            </FrameLayout>

            <!-- ── Order card (peach on caramel) ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_order_card"
                android:padding="22dp"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/label_place_order"
                    android:textColor="@color/color_primary_3"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- Quantity row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="18dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat"
                            android:text="@string/label_quantity"
                            android:textColor="@color/color_primary_3"
                            android:textSize="12.5sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_price_each"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/montserrat"
                            android:textColor="@color/color_grey"
                            android:textSize="11sp"
                            android:fontWeight="600"
                            tools:text="Rp 95.000 / book" />
                    </LinearLayout>

                    <!-- Minus button -->
                    <ImageView
                        android:id="@+id/btn_qty_minus"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_minus"
                        android:background="@drawable/bg_qty_btn"
                        android:scaleType="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="@null" />

                    <TextView
                        android:id="@+id/tv_qty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_marginEnd="14dp"
                        android:fontFamily="@font/montserrat"
                        android:text="1"
                        android:textColor="@color/color_primary_3"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:minWidth="18dp"
                        android:gravity="center" />

                    <!-- Plus button -->
                    <ImageView
                        android:id="@+id/btn_qty_plus"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_plus"
                        android:background="@drawable/bg_qty_btn"
                        android:scaleType="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="@null" />
                </LinearLayout>

                <!-- Delivery address label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/label_delivery_address"
                    android:textColor="@color/color_primary_3"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Delivery address input -->
                <EditText
                    android:id="@+id/et_address"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_input_field"
                    android:fontFamily="@font/montserrat"
                    android:hint="@string/hint_delivery_address"
                    android:imeOptions="actionNext"
                    android:inputType="textPostalAddress"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/color_primary_3"
                    android:textColorHint="@color/color_hint"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- Phone number label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/label_phone_number"
                    android:textColor="@color/color_primary_3"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Phone number input -->
                <EditText
                    android:id="@+id/et_phone"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp"
                    android:background="@drawable/bg_input_field"
                    android:fontFamily="@font/montserrat"
                    android:hint="@string/hint_phone_number"
                    android:imeOptions="actionDone"
                    android:inputType="phone"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/color_primary_3"
                    android:textColorHint="@color/color_hint"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- Total row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/label_total"
                        android:textColor="@color/color_primary_3"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/playfair_display"
                        android:textColor="@color/color_primary_2"
                        android:textSize="21sp"
                        android:textStyle="bold"
                        tools:text="Rp 95.000" />
                </LinearLayout>

                <!-- BUY NOW button (25dp height per Figma) -->
                <Button
                    android:id="@+id/btn_buy"
                    style="@style/Widget.BookWorm.Button.Primary"
                    android:layout_height="40dp"
                    android:textSize="12sp"
                    android:text="@string/btn_buy_now" />
            </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── Order success overlay ── -->
    <FrameLayout
        android:id="@+id/overlay_success"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="@color/color_overlay_dark"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:id="@+id/dialog_success"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_success_dialog"
            android:orientation="vertical"
            android:paddingStart="26dp"
            android:paddingEnd="26dp"
            android:paddingTop="30dp"
            android:paddingBottom="22dp"
            android:gravity="center"
            android:elevation="8dp"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="62dp"
                android:layout_height="62dp"
                android:background="@drawable/bg_success_icon"
                android:layout_marginBottom="18dp">
                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_check"
                    android:scaleType="fitCenter"
                    android:contentDescription="@null" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_order_confirmed"
                android:fontFamily="@font/montserrat"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="@color/color_primary_3" />

            <TextView
                android:id="@+id/tv_success_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="22dp"
                android:fontFamily="@font/playfair_display"
                android:textSize="13.5sp"
                android:textColor="@color/color_espresso_2"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4" />

            <Button
                android:id="@+id/btn_back_to_books"
                style="@style/Widget.BookWorm.Button.Primary"
                android:text="@string/btn_back_to_books" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
