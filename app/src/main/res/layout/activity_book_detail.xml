<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_secondary_1">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="40dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Top bar: back button + title ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="64dp">

                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_back"
                    android:tint="@color/color_primary_3"
                    android:background="@drawable/bg_back_btn"
                    android:scaleType="center"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/content_description_back" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/label_book_detail"
                    android:textColor="@color/color_primary_3"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ── Hero cover (centered, 162dp) ── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <!-- Glow beneath cover -->
                <View
                    android:layout_width="230dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="120dp"
                    android:background="@drawable/bg_cover_glow" />

                <!-- Cover view centered -->
                <com.example.bookworm.view.BookCoverView
                    android:id="@+id/book_cover"
                    android:layout_width="@dimen/cover_detail_width"
                    android:layout_height="38dp"
                    android:layout_gravity="center_horizontal"
                    android:elevation="8dp" />
            </FrameLayout>

            <!-- ── Title block ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="30dp"
                android:gravity="center">

                <!-- Tag badge -->
                <TextView
                    android:id="@+id/tv_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tag_badge"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:fontFamily="@font/montserrat"
                    android:textColor="@color/color_primary_1"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <!-- Book title -->
                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/montserrat"
                    android:textColor="@color/color_primary_3"
                    android:textSize="25sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.1" />

                <!-- Author -->
                <TextView
                    android:id="@+id/tv_author"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/playfair_display"
                    android:textColor="@color/color_primary_2"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ── Ornamental divider ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_gradient_line_left" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:fontFamily="@font/playfair_display"
                    android:text="❧"
                    android:textColor="@color/color_primary_1"
                    android:textSize="16sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_gradient_line_right" />
            </LinearLayout>

            <!-- ── Meta strip: Published | Pages | Genre ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_meta_strip"
                android:paddingTop="13dp"
                android:paddingBottom="13dp">

                <!-- Published -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_year"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/playfair_display"
                        android:textColor="@color/color_primary_3"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/label_published"
                        android:textColor="@color/color_grey"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/color_divider" />

                <!-- Pages -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_pages"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/playfair_display"
                        android:textColor="@color/color_primary_3"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/label_pages"
                        android:textColor="@color/color_grey"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/color_divider" />

                <!-- Genre -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_genre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/playfair_display"
                        android:textColor="@color/color_primary_3"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/label_genre"
                        android:textColor="@color/color_grey"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── About this book ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="26dp">

                <!-- Section heading row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/playfair_display"
                        android:text="❦"
                        android:textColor="@color/color_primary_1"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_marginEnd="10dp"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/label_about_book"
                        android:textColor="@color/color_primary_3"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/playfair_display"
                        android:text="❦"
                        android:textColor="@color/color_primary_1"
                        android:textSize="12sp"
                        android:rotation="180" />
                </LinearLayout>

                <!-- Blurb -->
                <TextView
                    android:id="@+id/tv_blurb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/playfair_display"
                    android:textColor="@color/color_primary_3"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.5"
                    android:gravity="start" />
            </LinearLayout>

            <!-- ── Order card ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_order_card"
                android:padding="22dp"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/label_place_order"
                    android:textColor="@color/color_primary_3"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- Quantity row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="18dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat"
                            android:text="@string/label_quantity"
                            android:textColor="@color/color_primary_3"
                            android:textSize="12.5sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_price_each"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/montserrat"
                            android:textColor="@color/color_grey"
                            android:textSize="11sp"
                            android:fontWeight="600" />
                    </LinearLayout>

                    <!-- Minus button -->
                    <ImageView
                        android:id="@+id/btn_qty_minus"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_minus"
                        android:background="@drawable/bg_qty_btn"
                        android:scaleType="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="@null" />

                    <TextView
                        android:id="@+id/tv_qty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_marginEnd="14dp"
                        android:fontFamily="@font/montserrat"
                        android:text="1"
                        android:textColor="@color/color_primary_3"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:minWidth="18dp"
                        android:gravity="center" />

                    <!-- Plus button -->
                    <ImageView
                        android:id="@+id/btn_qty_plus"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_plus"
                        android:background="@drawable/bg_qty_btn"
                        android:scaleType="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="@null" />
                </LinearLayout>

                <!-- Delivery address label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/label_delivery_address"
                    android:textColor="@color/color_primary_3"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Delivery address input -->
                <EditText
                    android:id="@+id/et_address"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_input_field"
                    android:fontFamily="@font/montserrat"
                    android:hint="@string/hint_delivery_address"
                    android:imeOptions="actionNext"
                    android:inputType="textPostalAddress"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/color_primary_3"
                    android:textColorHint="@color/color_hint"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- Phone number label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/label_phone_number"
                    android:textColor="@color/color_primary_3"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Phone number input -->
                <EditText
                    android:id="@+id/et_phone"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp"
                    android:background="@drawable/bg_input_field"
                    android:fontFamily="@font/montserrat"
                    android:hint="@string/hint_phone_number"
                    android:imeOptions="actionDone"
                    android:inputType="phone"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/color_primary_3"
                    android:textColorHint="@color/color_hint"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- Total row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/label_total"
                        android:textColor="@color/color_primary_3"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/playfair_display"
                        android:textColor="@color/color_primary_2"
                        android:textSize="21sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- BUY NOW button -->
                <Button
                    android:id="@+id/btn_buy"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_primary_height"
                    android:background="@drawable/bg_button_primary"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/btn_buy_now"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── Order success overlay ── -->
    <FrameLayout
        android:id="@+id/overlay_success"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="#80281810"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:id="@+id/dialog_success"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_success_dialog"
            android:orientation="vertical"
            android:paddingStart="26dp"
            android:paddingEnd="26dp"
            android:paddingTop="30dp"
            android:paddingBottom="22dp"
            android:gravity="center"
            android:elevation="8dp"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="62dp"
                android:layout_height="62dp"
                android:background="@drawable/bg_success_icon"
                android:layout_marginBottom="18dp">
                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_check"
                    android:scaleType="fitCenter"
                    android:contentDescription="@null"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_order_confirmed"
                android:fontFamily="@font/montserrat"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="@color/color_primary_3"/>

            <TextView
                android:id="@+id/tv_success_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="22dp"
                android:fontFamily="@font/playfair_display"
                android:textSize="13.5sp"
                android:textColor="@color/color_espresso_2"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4"/>

            <Button
                android:id="@+id/btn_back_to_books"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_primary_height"
                android:background="@drawable/bg_button_primary"
                android:text="@string/btn_back_to_books"
                android:textColor="@color/white"
                android:fontFamily="@font/montserrat"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:letterSpacing="0.05"/>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
