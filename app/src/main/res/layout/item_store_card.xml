<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_store_card"
    android:elevation="3dp"
    android:orientation="horizontal"
    android:paddingStart="18dp"
    android:paddingEnd="18dp"
    android:paddingTop="13dp"
    android:paddingBottom="12dp">

    <!-- Store image (129×126dp, clipped to 14dp rounded corners) -->
    <FrameLayout
        android:layout_width="129dp"
        android:layout_height="126dp"
        android:background="@drawable/bg_store_image"
        android:clipToOutline="true">

        <ImageView
            android:id="@+id/iv_store"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@null"
            tools:src="@drawable/store_4" />
    </FrameLayout>

    <!-- Store info (right side) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="13dp"
        android:layout_gravity="center_vertical"
        android:orientation="vertical">

        <!-- Store name -->
        <TextView
            android:id="@+id/tv_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/playfair_display"
            android:textColor="@color/color_primary_3"
            android:textSize="16sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.2"
            android:maxLines="2"
            tools:text="Ivory Tower Books" />

        <!-- Address row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_nav_pin"
                android:tint="@color/color_primary_1"
                android:scaleType="fitCenter"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/tv_address"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="@font/montserrat"
                android:textColor="@color/color_primary_3"
                android:textSize="12sp"
                android:fontWeight="500"
                android:maxLines="2"
                tools:text="Jl. Braga No. 18, Bandung" />
        </LinearLayout>

        <!-- Contact row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_phone"
                android:tint="@color/color_primary_1"
                android:scaleType="fitCenter"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/tv_contact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="@font/montserrat"
                android:textColor="@color/color_primary_3"
                android:textSize="12sp"
                android:fontWeight="500"
                tools:text="+62 812 3344 5566" />
        </LinearLayout>

        <!-- Hours row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_clock"
                android:tint="@color/color_primary_1"
                android:scaleType="fitCenter"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/tv_hours"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="@font/montserrat"
                android:textColor="@color/color_primary_3"
                android:textSize="12sp"
                android:fontWeight="500"
                tools:text="09:00 – 21:00" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
