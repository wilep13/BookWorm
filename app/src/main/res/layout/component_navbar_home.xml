<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="92dp"
    android:layout_gravity="bottom"
    android:elevation="8dp"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_nav_pill_home"
        android:scaleType="fitXY"
        android:contentDescription="@null" />

    <!-- Home icon (active — cream) centered in bubble at (69, 22) -->
    <ImageView
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="60dp"
        android:layout_marginTop="12dp"
        android:src="@drawable/ic_nav_home_v2"
        android:tint="@color/color_secondary_2"
        android:scaleType="fitCenter"
        android:contentDescription="@string/nav_home" />

    <!-- Books icon (inactive) — center at (158, 45) -->
    <ImageView
        android:id="@+id/nav_books"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="146dp"
        android:layout_marginTop="33dp"
        android:src="@drawable/ic_nav_books_v2"
        android:tint="@color/color_primary_3"
        android:scaleType="fitCenter"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/nav_books" />

    <!-- Stores icon (inactive) — center at (246, 45) -->
    <ImageView
        android:id="@+id/nav_stores"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="234dp"
        android:layout_marginTop="33dp"
        android:src="@drawable/ic_nav_cart"
        android:tint="@color/color_primary_3"
        android:scaleType="fitCenter"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/nav_stores" />

    <!-- Logout icon (inactive) — center at (342, 45) -->
    <ImageView
        android:id="@+id/nav_logout"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="330dp"
        android:layout_marginTop="33dp"
        android:src="@drawable/ic_nav_logout"
        android:tint="@color/color_primary_3"
        android:scaleType="fitCenter"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/nav_logout" />

</FrameLayout>
