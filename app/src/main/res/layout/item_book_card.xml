<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:clickable="true"
    android:focusable="true">

    <com.example.bookworm.view.BookCoverView
        android:id="@+id/book_cover_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:background="@color/color_primary_1" />

    <TextView
        android:id="@+id/tv_tag"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/montserrat"
        android:textColor="@color/color_grey"
        android:textSize="9sp"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:textStyle="bold"
        android:visibility="gone"
        tools:text="FICTION"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/montserrat"
        android:textColor="@color/color_primary_3"
        android:textSize="11.5sp"
        android:textStyle="bold"
        android:lineSpacingMultiplier="1.2"
        android:maxLines="2"
        android:ellipsize="end"
        tools:text="The Great Gatsby" />

    <TextView
        android:id="@+id/tv_author"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:fontFamily="@font/playfair_display"
        android:textColor="@color/color_primary_1"
        android:textSize="13sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        tools:text="F. Scott Fitzgerald" />
</LinearLayout>
