<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:clickable="true"
    android:focusable="true">

    <!-- Cover stack: page-block + ribbon + clothbound cover -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Page block (behind cover, offset 6dp right + 6dp down) -->
        <View
            android:id="@+id/page_block"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_page_block" />

        <!-- Ribbon (caramel bookmark strip, ~78% from left) -->
        <View
            android:id="@+id/ribbon"
            android:layout_width="8dp"
            android:layout_height="match_parent"
            android:layout_marginTop="-2dp"
            android:layout_gravity="start"
            android:translationX="0dp"
            android:background="@color/color_primary_1" />

        <!-- Clothbound cover (custom view) -->
        <com.example.bookworm.view.BookCoverView
            android:id="@+id/book_cover_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </FrameLayout>

    <!-- Text below cover -->
    <TextView
        android:id="@+id/tv_tag"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/montserrat"
        android:textColor="@color/color_grey"
        android:textSize="9sp"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/montserrat"
        android:textColor="@color/color_primary_3"
        android:textSize="12.5sp"
        android:textStyle="bold"
        android:lineSpacingMultiplier="1.2"
        android:maxLines="2"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/tv_author"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:fontFamily="@font/playfair_display"
        android:textColor="@color/color_primary_1"
        android:textSize="13.5sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end" />
</LinearLayout>
