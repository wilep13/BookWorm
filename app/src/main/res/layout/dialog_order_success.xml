<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_success_dialog"
    android:orientation="vertical"
    android:paddingStart="26dp"
    android:paddingEnd="26dp"
    android:paddingTop="30dp"
    android:paddingBottom="22dp"
    android:gravity="center">

    <FrameLayout
        android:layout_width="62dp"
        android:layout_height="62dp"
        android:background="@drawable/bg_success_icon"
        android:layout_marginBottom="18dp">
        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_check"
            android:scaleType="fitCenter"
            android:contentDescription="@null" />
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_order_confirmed"
        android:fontFamily="@font/montserrat"
        android:textSize="19sp"
        android:textStyle="bold"
        android:textColor="@color/color_primary_3" />

    <TextView
        android:id="@+id/tv_success_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="22dp"
        android:fontFamily="@font/playfair_display"
        android:textSize="13.5sp"
        android:textColor="@color/color_espresso_2"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4" />

    <Button
        android:id="@+id/btn_back_to_books"
        style="@style/Widget.BookWorm.Button.Primary"
        android:text="@string/btn_back_to_books" />

</LinearLayout>
