<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_books_screen"
    tools:context=".ui.home.BooksFragment">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsv_books"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Header ── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="64dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Figma: Montserrat Bold 12sp, letterSpacing, Primary 1 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/kicker_books"
                        android:textColor="@color/color_primary_1"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.12" />

                    <!-- Figma: Playfair Display Bold 24sp (H2), Primary 3 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/playfair_display"
                        android:text="@string/title_our_library"
                        android:textColor="@color/color_primary_3"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <!-- Figma: Montserrat Regular 16sp, Primary 3 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/subtitle_timeless"
                        android:textColor="@color/color_primary_3"
                        android:textSize="16sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="@dimen/avatar_size"
                    android:layout_height="@dimen/avatar_size"
                    android:layout_gravity="end"
                    android:background="@drawable/bg_avatar"
                    android:src="@drawable/ic_account_circle"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:elevation="4dp"
                    android:contentDescription="@null" />
            </FrameLayout>

            <!-- ── Segmented tabs ── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_segmented_tab"
                android:padding="5dp">

                <View
                    android:id="@+id/tab_indicator"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_segmented_active"
                    tools:layout_width="151dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tab_non_fiction"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/tab_non_fiction"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/tab_fiction"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/tab_fiction"
                        android:textColor="@color/color_primary_3"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </FrameLayout>

            <!-- ── Book grid ── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_books"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2"
                tools:listitem="@layout/item_book_card"
                tools:itemCount="6" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</FrameLayout>
