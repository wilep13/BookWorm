<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_secondary_1"
    tools:context=".ui.home.HomeFragment">

    <com.example.bookworm.view.ScrollableNestedScrollView
        android:id="@+id/nsv_home"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Header row ── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="64dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Figma: Montserrat Bold 16sp, letterSpacing 0.12, Primary 1 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/caption_welcome_back"
                        android:textColor="@color/color_primary_1"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.12" />

                    <!-- Figma: Playfair Display 28sp, Primary 3 -->
                    <TextView
                        android:id="@+id/tv_greeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/playfair_display"
                        android:text="@string/greeting_hello"
                        android:textColor="@color/color_primary_3"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        tools:text="Hello, Stieven!" />

                    <!-- Figma: Montserrat Bold 16sp, Primary 3 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/subtitle_nice_day"
                        android:textColor="@color/color_primary_3"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="@dimen/avatar_size"
                    android:layout_height="@dimen/avatar_size"
                    android:layout_gravity="end"
                    android:background="@drawable/bg_avatar"
                    android:src="@drawable/ic_account_circle"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@null" />
            </FrameLayout>

            <!-- ── Carousel ── -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/vp_carousel"
                android:layout_width="match_parent"
                android:layout_height="@dimen/carousel_height"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="22dp" />

            <!-- ── Dots + prev/next ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="11dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btn_carousel_prev"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_chevron_left"
                    android:tint="@color/color_primary_2"
                    android:background="@drawable/bg_carousel_btn"
                    android:scaleType="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@null" />

                <!-- Dots (built programmatically at runtime; design-time placeholders below) -->
                <LinearLayout
                    android:id="@+id/ll_dots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Design-time dot placeholders (runtime: removeAllViews() clears these) -->
                    <View
                        android:layout_width="20dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_dot_active"
                        android:visibility="gone"
                        tools:visibility="visible" />
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginStart="7dp"
                        android:background="@drawable/bg_dot_inactive"
                        android:visibility="gone"
                        tools:visibility="visible" />
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginStart="7dp"
                        android:background="@drawable/bg_dot_inactive"
                        android:visibility="gone"
                        tools:visibility="visible" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/btn_carousel_next"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/color_primary_2"
                    android:background="@drawable/bg_carousel_btn"
                    android:scaleType="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@null" />
            </LinearLayout>

            <!-- ── Featured Books header ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Figma: Montserrat Bold 16sp, Primary 3 -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/section_featured_books"
                    android:textColor="@color/color_primary_3"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Figma: Montserrat Bold 12sp, Primary 2 - 80 (#9F6F53) -->
                <TextView
                    android:id="@+id/tv_see_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/btn_see_all"
                    android:textColor="@color/color_primary_2_80"
                    android:textSize="12sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ── Featured book grid ── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_books"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="16dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2"
                tools:listitem="@layout/item_book_card"
                tools:itemCount="4" />
        </LinearLayout>
    </com.example.bookworm.view.ScrollableNestedScrollView>

</FrameLayout>
