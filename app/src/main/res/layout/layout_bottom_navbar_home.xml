<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/navbar_total_height">

    <!-- Brown bar background (starts 10dp from top, leaving space for raised circle) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/navbar_height"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_navbar_bar" />

    <!-- Subtract cutout (cream overlay creating curved dip under Home circle) -->
    <ImageView
        android:layout_width="79dp"
        android:layout_height="46dp"
        android:layout_marginStart="62dp"
        android:layout_marginTop="21dp"
        android:src="@drawable/ic_navbar_subtract"
        android:scaleType="fitXY"
        android:contentDescription="@null" />

    <!-- Active circle for Home tab -->
    <ImageView
        android:layout_width="49dp"
        android:layout_height="49dp"
        android:layout_marginStart="44dp"
        android:src="@drawable/ic_navbar_circle"
        android:contentDescription="@null" />

    <!-- Home icon (active — cream white, elevated on circle) -->
    <ImageView
        android:layout_width="78dp"
        android:layout_height="40dp"
        android:layout_marginStart="30dp"
        android:layout_marginTop="2dp"
        android:src="@drawable/ic_nav_home_active"
        android:scaleType="fitCenter"
        android:contentDescription="@string/nav_home" />

    <!-- Books icon (inactive, on bar) -->
    <ImageView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="140dp"
        android:layout_marginTop="27dp"
        android:src="@drawable/ic_nav_books"
        android:scaleType="fitCenter"
        android:contentDescription="@string/nav_books" />

    <!-- Cart icon (inactive, on bar) -->
    <ImageView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="225dp"
        android:layout_marginTop="27dp"
        android:src="@drawable/ic_nav_cart"
        android:scaleType="fitCenter"
        android:contentDescription="@string/nav_cart" />

    <!-- Explore icon (inactive, on bar) -->
    <ImageView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="321dp"
        android:layout_marginTop="27dp"
        android:src="@drawable/ic_nav_explore"
        android:scaleType="fitCenter"
        android:contentDescription="@string/nav_explore" />

    <!-- Transparent click areas overlaid on top -->
    <View
        android:id="@+id/nav_home"
        android:layout_width="98dp"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground" />

    <View
        android:id="@+id/nav_books"
        android:layout_width="98dp"
        android:layout_height="match_parent"
        android:layout_marginStart="98dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground" />

    <View
        android:id="@+id/nav_cart"
        android:layout_width="98dp"
        android:layout_height="match_parent"
        android:layout_marginStart="196dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground" />

    <View
        android:id="@+id/nav_explore"
        android:layout_width="98dp"
        android:layout_height="match_parent"
        android:layout_marginStart="294dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground" />
</FrameLayout>
