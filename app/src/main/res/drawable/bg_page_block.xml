<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F4ECE0" />
            <corners android:topRightRadius="5dp" android:bottomRightRadius="5dp" />
        </shape>
    </item>
    <item android:right="0dp" android:left="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#E7DAC8"
                android:endColor="#F4ECE0"
                android:gradientRadius="6dp" />
        </shape>
    </item>
</layer-list>
